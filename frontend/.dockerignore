# Dependencies — pnpm's symlinked node_modules breaks inside the image; deps stage installs fresh
node_modules

# Build artifacts — regenerated by `pnpm run build` in the builder stage
.next
out

# Secrets / env — provided at runtime via compose env_file; keep them out of image layers
.envs/
.env*.local

# VCS
.git
.gitignore

# Logs
*-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor cruft
.DS_Store
.idea
.vscode

# AI / agent tooling (not needed at runtime)
AGENTS.md
AGENT.md
CLAUDE.md
GEMINI.md
.claude/
.cursor/
.cursorrules
.windsurfrules
.aider*
.github/copilot-instructions.md
