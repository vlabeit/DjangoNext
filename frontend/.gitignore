# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
# NOTE: do NOT use `.env*` here — it matches the `.envs/` directory and git
# cannot re-include files under an ignored directory, which would suppress the
# tracked *.example seed files. List the bare dotenv files explicitly instead.
.env
.env.local
.env.development.local
.env.production.local
!.env*.example
!.envs/
!.envs/**/*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
